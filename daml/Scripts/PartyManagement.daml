--   debug $ "    >> Found " <> show (length registries) <> " registries"
--   case registries of
--     (registryCid, registry) :: _ -> do
--       debug $ "     Using existing registry with admin: " <> show registry.admin
--       return (Some (registryCid, registry))
--     [] -> do
--       return None

findExistingRegistryInternal : Party -> Script (Optional (ContractId PartyRegistry, PartyRegistry))
findExistingRegistryInternal expectedAdmin = do
  -- Query the registry using the admin party as the key
  optRegistries <- queryContractKey @PartyRegistry expectedAdmin expectedAdmin
  case optRegistries of
    Some (registryCid, registry) -> do
      if registry.admin == expectedAdmin then do
        return (Some (registryCid, registry))
      else do
        debug $ "     Registry admin: " <> show registry.admin <> " does not match expected admin: " <> show expectedAdmin
        return None
    None -> do
      debug $ "     No registry found for admin: " <> show expectedAdmin
      return None

-- Initialize the party registry with admin
initializeRegistry : Script (ContractId PartyRegistry)
initializeRegistry = do
  admin <- getOrCreateAdminParty
  debug $ " - Initializing registry with admin: " <> show admin
  
  -- Check if registry already exists
  existingRegistry <- findExistingRegistryInternal admin
  case existingRegistry of
    Some (registryCid, registry) -> do
      debug $ "     Registry already exists with ID: " <> show registryCid
      debug $ "     Registry admin: " <> show registry.admin
      debug $ "     Registry parties: " <> show registry.registeredParties
      debug "       >> Registry initialization skipped - using existing registry!"
      return registryCid
    None -> do
      debug " - Creating new registry..."
      registryCid <- submit admin do
        createCmd PartyRegistry with
          admin = admin
          registeredParties = [admin]
      debug $ "     Registry initialized with admin: " <> show admin
      debug $ "     Registry contract ID: " <> show registryCid
      debug "       >> Registry initialized successfully!"
      return registryCid

-- Allocate a new party and register it in the party registry
allocateAndRegisterParty : Party -> Text -> Script Party
allocateAndRegisterParty admin name = do
  -- admin <- getOrCreateAdminParty
  
  -- Find the registry
  existingRegistry <- findExistingRegistryInternal admin
  case existingRegistry of
    Some (registryCid, registry) -> do
      debug $ "     Using existing registry: " <> show registryCid
      
      -- Check if party already exists
      party <- getOrCreateParty name
      
      -- Check if party is already registered
      if party `elem` registry.registeredParties
      then do
        debug $ " - Party '" <> name <> "' is already registered"
        debug "       >> Party registration skipped - already exists!"
        return party
      else do
        -- Register the party
        newRegistryCid <- submit admin do
          exerciseCmd registryCid RegisterParty with
            newParty = party
        debug $ "     Party '" <> name <> "' registered successfully"
        debug $ "     Party ID: " <> show party
        debug $ "     New registry ID: " <> show newRegistryCid
        debug "       >> Party registration completed!"
        return party
        
    None -> do
      debug " - No registry found, creating new one..."
      party <- getOrCreateParty name
      
      registryCid <- submit admin do
        createCmd PartyRegistry with
          admin = admin
          registeredParties = [admin, party]
      
      debug $ "     >> Created new registry with parties: [" <> show admin <> ", " <> show party <> "]"
      debug $ "        - Party '" <> name <> "' added successfully!"
      debug $ "          Party ID: " <> show party
      return party

allocateAndRegisterParties: Party -> [Text] -> Script [Party]
allocateAndRegisterParties admin names = forA names (\name -> allocateAndRegisterParty admin name)

-- List all registered parties
listRegisteredParties : Party -> Script [Party]
listRegisteredParties admin = do
  existingRegistry <- findExistingRegistryInternal admin
  case existingRegistry of
    Some (registryCid, _) -> do
      parties <- submit admin do
        exerciseCmd registryCid ListParties
      debug $ "     >> Registered parties: "
      forA_ parties (\p -> debug $ "       - " <> show p)
      return parties
    None -> do
      return []

-- Check if a party is registered
checkPartyRegistration : Party -> Text -> Script Bool
checkPartyRegistration admin name = do
  -- admin <- getOrCreateAdminParty
  
  existingRegistry <- findExistingRegistryInternal admin
  case existingRegistry of
    Some (registryCid, _) -> do
      -- Try to find the party
      parties <- listKnownParties
      case find (\p -> p.displayName == Some name) parties of
        Some partyDetails -> do
          isRegistered <- submit admin do
            exerciseCmd registryCid IsPartyRegistered with
              party = partyDetails.party
              requester = admin
          debug $ "   - Party '" <> name <> "' registration status: " <> show isRegistered
          return isRegistered
        None -> do
          debug $ "     >> Party '" <> name <> "' not found on ledger"
          return False
    None -> do
      -- debug "   - No registry found"
      return False

-- Remove a party from the registry
removeParty : Party -> Text -> Script ()
removeParty admin name = do
  -- admin <- getOrCreateAdminParty
  
  existingRegistry <- findExistingRegistryInternal admin
  case existingRegistry of
    Some (registryCid, _) -> do
      -- Get the party by name
      party <- getPartyByName name
      case party of
        Some party -> do
          newRegistryCid <- submit admin do
            exerciseCmd registryCid UnregisterParty with
              partyToRemove = party
          debug $ "   Party '" <> name <> "' removed successfully"
          debug $ "     >> New registry ID: " <> show newRegistryCid
          return ()
        None -> do
          debug $ "   >> Party '" <> name <> "' not found on ledger"
          return ()
    None -> do
      -- debug "   - No registry found"
      return ()

