module Exchange.TokenListingUtils where

import DA.Optional
import Exchange.TokenListing

ensureListingsAreActive: Party -> (Party, Text) -> (Party, Text) -> Update ()
ensureListingsAreActive admin inputMasterKey quoteMasterKey = do
  let inputListingKey = (admin, inputMasterKey)
  inputListingOpt <- lookupByKey @TokenListing inputListingKey
  assertMsg ("Input token " <> inputMasterKey._2 <> " is no longer listed.") (isSome inputListingOpt)

  let quoteListingKey = (admin, quoteMasterKey)
  quoteListingOpt <- lookupByKey @TokenListing quoteListingKey
  assertMsg ("Quote token " <> quoteMasterKey._2 <> " is no longer listed.") (isSome quoteListingOpt)

  return ()