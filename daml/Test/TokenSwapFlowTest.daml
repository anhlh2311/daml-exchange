module Test.TokenSwapFlowTest where

import Daml.Script
import DA.Assert ((===))
import DA.Optional
import Currency.TokenLedger
import Currency.TokenMetadata
import Exchange.TokenSwap
import Exchange.TokenPair
import Exchange.TokenSwapUtils

import Scripts.PartyManagement
import Scripts.PartyUtils
import Scripts.TokenPairUtils
import Scripts.SwapUtils
import Scripts.SetupUtils

sellingPrice: Decimal = 109512.0
buyingPrice: Decimal = 109483.0

initializeLedger : Decimal -> Decimal -> Decimal -> Decimal -> Script (ContractId TokenPair, (Party, (Party, Text), (Party, Text)), [Party])
initializeLedger btcInitialSupply usdtInitialSupply sellingPrice buyingPrice = do
  -- Registry setup & party registration
  registryCid <- initializeRegistry
  adminOpt <- getAdminParty
  let admin = fromSome adminOpt
  [alice, bob, lp, btcOwner, usdtOwner] <- allocateAndRegisterParties admin ["Alice", "Bob", "LiquidityProvider", "BtcOwner", "UsdtOwner"]

  -- Token setup
  btcMetadata <- createMetadata "Bitcoin" "BTC" "Decentralized digital currency" 8
  usdtMetadata <- createMetadata "Tether" "USDT" "Stablecoin pegged to USD" 6

  -- Initializing BTC and USDT tokens
  (btcMasterCid, btcOwnerLedgerCid) <- createToken 
    btcOwner btcMetadata btcInitialSupply admin

  (usdtMasterCid, usdtOwnerLedgerCid) <- createToken 
    usdtOwner usdtMetadata usdtInitialSupply admin

  -- Create token listings
  let
    btcMasterKey = (btcOwner, btcMetadata.symbol)
    usdtMasterKey = (usdtOwner, usdtMetadata.symbol)

  -- create token listing
  (btcListingCid, btcListingKey) <- createTokenListing btcOwner admin btcMetadata.symbol admin

  (usdtListingCid, usdtListingKey) <- createTokenListing usdtOwner admin usdtMetadata.symbol admin

  -- Create token pair using listings
  tokenPairSetupCid <- createTokenPairSetup admin lp btcMasterKey usdtMasterKey admin

  -- Create a token pair using listings
  tokenPairCid <- createTokenPairWithSetup admin tokenPairSetupCid sellingPrice buyingPrice admin

  -- Fund Alice and Liquidity Provider
  -- create USDT TokenTransferLock for Alice
  aliceTokenTransferLockCid <- createTokenTransferLock usdtOwner alice usdtOwnerLedgerCid 200000.0

  -- create BTC TokenTransferLock for Liquidity Provider
  lpTokenTransferLockCid <- createTokenTransferLock btcOwner lp btcOwnerLedgerCid 10.0

  -- Accept the TokenTransferLock for Alice
  aliceTokenLedgerCid <- acceptTokenTransfer alice aliceTokenTransferLockCid

  -- Accept the TokenTransferLock for Liquidity Provider
  lpTokenLedgerCid <- acceptTokenTransfer lp lpTokenTransferLockCid

  let btcUsdtTokenPairKey = (admin, btcMasterKey, usdtMasterKey)
  
  activeBTCUSDTTokenPairOpt <- getActiveTokenPairByKey admin btcUsdtTokenPairKey
  let activeBTCUSDTTokenPairCid = (fromSome activeBTCUSDTTokenPairOpt)

  return (activeBTCUSDTTokenPairCid, btcUsdtTokenPairKey, [admin, alice, bob, lp, btcOwner, usdtOwner])

testSwapSuccess = do
  (activeBTCUSDTTokenPairCid, 
    btcUsdtTokenPairKey, 
    [admin, alice, bob, lp, btcOwner, usdtOwner]) <- initializeLedger 100.0 1000000000.0 109512.0 109483.0
  let (admin, btcMasterKey, usdtMasterKey) = btcUsdtTokenPairKey

  debug "---------------------------------"
  debug "Test swap success USDT -> BTC"
  debug "---------------------------------"

  -- Get the rate of the token pair
  (sellingPrice, buyingPrice) <- submit alice do
    exerciseCmd activeBTCUSDTTokenPairCid GetRate with requester = alice

  -- sellingPrice === 109512.0
  sellingPrice === Test.TokenSwapFlowTest.sellingPrice
  -- buyingPrice === 109483.0
  buyingPrice === Test.TokenSwapFlowTest.buyingPrice

  -- Alice wants to buy BTC with 1095.12 USDT
  let 
    usdtInputAmount: Decimal = 1095.12
    btcInputAmount: Decimal = 1.0
    slippageTolerance: Decimal = 0.05

  -- Calculate the amount of BTC that Alice will receive when she buys BTC with USDT
  let estimatedReceivingBtcAmount = calculateSellingAmount usdtInputAmount sellingPrice
  debug $ "Estimated receiving amount of BTC for " <> show usdtInputAmount <> " USDT: " <> show estimatedReceivingBtcAmount

  -- Calculate the amount of USDT that Alice will receive when she sells BTC for USDT
  let estimatedReceivingUsdtAmount = calculateBuyingAmount btcInputAmount buyingPrice
  debug $ "Estimated receiving amount of USDT for " <> show btcInputAmount <> " BTC: " <> show estimatedReceivingUsdtAmount

  -- Query the token ledger of Alice before swap
  debug "---------------------------------"
  debug "Query the token ledger of Alice before swap"
  aliceUsdtTokenLedgerOpt <- queryContractKey @TokenLedger alice (usdtOwner, alice)
  let aliceUsdtTokenLedger = (fromSome aliceUsdtTokenLedgerOpt)._2
  debug $ "Alice token balance of " <> aliceUsdtTokenLedger.symbol <> " before swap is: " <> show aliceUsdtTokenLedger.amount
  debug "---------------------------------"

  -- Alice create a TokenSwapRequest
  usdtToBtcSwapRequestCid <- createSwapWithTokenLocking 
    alice admin lp 
    (usdtOwner, alice) btcUsdtTokenPairKey 
    usdtInputAmount estimatedReceivingBtcAmount 
    slippageTolerance
    admin
  debug $ "Swap request CID: " <> show usdtToBtcSwapRequestCid

  [(requestCid, request)] <- query @SwapRequest alice
  requestCid === usdtToBtcSwapRequestCid
  request.swapper === alice
  request.admin === admin
  request.liquidityProvider === lp
  request.tokenPairKey === btcUsdtTokenPairKey
  request.inputAmount === usdtInputAmount
  request.expectedOutputAmount === estimatedReceivingBtcAmount

  debug $ "Swap request created: " <> show request

  debug "---------------------------------"

  -- Liquidity Provider accept the SwapRequest
  debug "Liquidity Provider accept the SwapRequest"
  -- (aliceBtcTokenLedgerCid, lpUsdtTokenLedgerCid) <- liquidityResponseWithSwapExecution
  --   lp alice admin usdtToBtcSwapRequestCid (btcOwner, lp) admin
  (lpUsdtTokenLedgerCid, acceptedSwapRequestCid) <- submit lp do
    exerciseCmd usdtToBtcSwapRequestCid AcceptSwap with
      outputTokenLedgerKey = (btcOwner, lp)

  -- debug $ "Alice BTC token ledger CID: " <> show aliceBtcTokenLedgerCid
  debug $ "LP USDT token ledger CID: " <> show lpUsdtTokenLedgerCid

  debug "---------------------------------"

  -- Alice finalize the swap
  debug "Alice finalize the swap"
  aliceBtcTokenLedgerCid <- submit alice do
    exerciseCmd acceptedSwapRequestCid FinalizeSwap

  -- Alice check the BTC token ledger by querying the TokenLedger contract Id returned by the confirmSwap choice
  aliceBtcTokenLedgerOpt <- queryContractId alice aliceBtcTokenLedgerCid
  let aliceBtcTokenLedger = (fromSome aliceBtcTokenLedgerOpt)
  debug $ "Alice token balance of " <> aliceBtcTokenLedger.symbol <> " is: " <> show aliceBtcTokenLedger.amount

  -- Alice check the USDT token ledger
  aliceUsdtTokenLedgerOpt <- queryContractKey @TokenLedger alice (usdtOwner, alice)
  let aliceUsdtTokenLedger = (fromSome aliceUsdtTokenLedgerOpt)._2
  debug $ "Alice token balance of " <> aliceUsdtTokenLedger.symbol <> " is: " <> show aliceUsdtTokenLedger.amount

  -- Liquidity Provider check the USDT token ledger by querying the TokenLedger contract Id returned by the confirmSwap choice
  lpUsdtTokenLedgerOpt <- queryContractId lp lpUsdtTokenLedgerCid
  let lpUsdtTokenLedger = (fromSome lpUsdtTokenLedgerOpt)
  debug $ "Liquidity Provider token balance of " <> lpUsdtTokenLedger.symbol <> " is: " <> show lpUsdtTokenLedger.amount

  -- Liquidity Provider check the BTC token ledger
  lpBtcTokenLedgerOpt <- queryContractKey @TokenLedger lp (btcOwner, lp)
  let lpBtcTokenLedger = (fromSome lpBtcTokenLedgerOpt)._2
  debug $ "Liquidity Provider token balance of " <> lpBtcTokenLedger.symbol <> " is: " <> show lpBtcTokenLedger.amount

  aliceBtcTokenLedger.amount === estimatedReceivingBtcAmount
  lpUsdtTokenLedger.amount === usdtInputAmount

  debug "---------------------------------"
  debug "Test swap success BTC -> USDT"
  debug "---------------------------------"

  -- Get the rate of the token pair
  (sellingPrice, buyingPrice) <- submit alice do
    exerciseCmd activeBTCUSDTTokenPairCid GetRate with requester = alice

  -- sellingPrice === 109512.0
  sellingPrice === Test.TokenSwapFlowTest.sellingPrice
  -- buyingPrice === 109483.0
  buyingPrice === Test.TokenSwapFlowTest.buyingPrice

  -- Alice wants to sell 0.005 BTC from her current balance for USDT
  let 
    btcInputAmount: Decimal = 0.005
    slippageTolerance: Decimal = 0.05
    inputTokenLedgerKey: (Party, Party) = (btcOwner, alice)
    outputTokenLedgerKey: (Party, Party) = (usdtOwner, lp)

  -- Query Alice's BTC token ledger
  aliceBtcTokenLedgerOpt <- queryContractKey @TokenLedger alice inputTokenLedgerKey
  let aliceBtcTokenLedger = (fromSome aliceBtcTokenLedgerOpt)._2
  debug $ "Alice token balance of " <> aliceBtcTokenLedger.symbol <> " is: " <> show aliceBtcTokenLedger.amount

  -- Calculate the amount of USDT that Alice will receive when she sells 0.005 BTC for USDT
  let estimatedReceivingUsdtAmount = calculateBuyingAmount btcInputAmount buyingPrice
  debug $ "Estimated receiving amount of USDT for " <> show btcInputAmount <> " BTC: " <> show estimatedReceivingUsdtAmount

  -- Alice create a new swap request
  btcToUsdtSwapRequestCid <- createSwapWithTokenLocking 
    alice admin lp
    inputTokenLedgerKey btcUsdtTokenPairKey
    btcInputAmount estimatedReceivingUsdtAmount
    slippageTolerance
    admin

  -- Query the swap request payload
  btcToUsdtSwapRequest <- queryContractId alice btcToUsdtSwapRequestCid

  debug $ "BTC to USDT swap request CID: " <> show btcToUsdtSwapRequestCid
  debug $ "BTC to USDT swap request: " <> show btcToUsdtSwapRequest

  -- Liquidity Provider accept the swap request
  debug "Liquidity Provider accept the swap request"
  -- (aliceBtcTokenLedgerCid, lpUsdtTokenLedgerCid) <- liquidityResponseWithSwapExecution
  --   lp alice admin btcToUsdtSwapRequestCid outputTokenLedgerKey admin
  (lpBtcTokenLedgerCid, acceptedSwapRequestCid) <- submit lp do
    exerciseCmd btcToUsdtSwapRequestCid AcceptSwap with
      outputTokenLedgerKey = outputTokenLedgerKey

  debug $ "LP BTC token ledger CID: " <> show lpBtcTokenLedgerCid
  debug $ "Accepted swap request CID: " <> show acceptedSwapRequestCid

  -- Alice finalize the swap
  aliceUsdtTokenLedgerCid <- submit alice do
    exerciseCmd acceptedSwapRequestCid FinalizeSwap

  -- Alice check the BTC token ledger
  aliceBtcTokenLedgerOpt <- queryContractKey @TokenLedger alice (btcOwner, alice)
  let aliceBtcTokenLedger = (fromSome aliceBtcTokenLedgerOpt)._2
  debug $ "Alice token balance of " <> aliceBtcTokenLedger.symbol <> " is: " <> show aliceBtcTokenLedger.amount

  -- Alice check the USDT token ledger
  aliceUsdtTokenLedgerOpt <- queryContractKey @TokenLedger alice (usdtOwner, alice)
  let aliceUsdtTokenLedger = (fromSome aliceUsdtTokenLedgerOpt)._2
  debug $ "Alice token balance of " <> aliceUsdtTokenLedger.symbol <> " is: " <> show aliceUsdtTokenLedger.amount

  -- Liquidity Provider check the BTC token ledger
  lpBtcTokenLedgerOpt <- queryContractKey @TokenLedger lp (btcOwner, lp)
  let lpBtcTokenLedger = (fromSome lpBtcTokenLedgerOpt)._2
  debug $ "Liquidity Provider token balance of " <> lpBtcTokenLedger.symbol <> " is: " <> show lpBtcTokenLedger.amount

  return ()

  
testSwapFailureWithInsufficientInputAmount = do
  (activeBTCUSDTTokenPairCid, 
    btcUsdtTokenPairKey, 
    [admin, alice, bob, lp, btcOwner, usdtOwner]) <- initializeLedger 100.0 1000000000.0 109512.0 109483.0
  let (admin, btcMasterKey, usdtMasterKey) = btcUsdtTokenPairKey

  debug "---------------------------------"
  debug "Test swap failure with insufficient input amount"
  debug "---------------------------------"

  -- Alice create a new swap request with input amount lower than required amount to swap 0.01 BTC
  debug "Alice create a swap request with input amount lower than required amount to swap 0.01 BTC"
  let 
    usdtInputAmount: Decimal = 1085.00
    slippageTolerance: Decimal = 0.05
    expectedBtcOutputAmount: Decimal = 0.01

  -- create a new swap request
  try do
    swapRequestCid <- createSwapWithTokenLocking 
      alice admin lp 
      (usdtOwner, alice) btcUsdtTokenPairKey 
      usdtInputAmount expectedBtcOutputAmount
      slippageTolerance
      admin

    return ()
  catch
    AssertionFailed msg -> do
      debug $ "Assertion failure in createSwapWithTokenLocking: " <> msg
  
  return () 

testSwapFailureWithFinalizeSwapBeforeAcceptSwap = do
  (activeBTCUSDTTokenPairCid, 
    btcUsdtTokenPairKey, 
    [admin, alice, bob, lp, btcOwner, usdtOwner]) <- initializeLedger 100.0 1000000000.0 109512.0 109483.0
  let (admin, btcMasterKey, usdtMasterKey) = btcUsdtTokenPairKey

  debug "---------------------------------"
  debug "Test swap failure with finalize swap before accept swap"
  debug "---------------------------------"

  -- Alice create a new swap request
  debug "Alice create a new swap request"
  let 
    usdtInputAmount: Decimal = 1095.12
    btcInputAmount: Decimal = 1.0
    slippageTolerance: Decimal = 0.05

    
    inputTokenLedgerKey: (Party, Party) = (btcOwner, alice)
    outputTokenLedgerKey: (Party, Party) = (usdtOwner, lp)
    estimatedReceivingBtcAmount = calculateSellingAmount usdtInputAmount Test.TokenSwapFlowTest.sellingPrice

  usdtToBtcSwapRequestCid <- createSwapWithTokenLocking 
    alice admin lp 
    (usdtOwner, alice) btcUsdtTokenPairKey 
    usdtInputAmount estimatedReceivingBtcAmount 
    slippageTolerance
    admin

  debug $ "BTC to USDT swap request CID: " <> show usdtToBtcSwapRequestCid

  -- Alice try to finalize the swap before getting accepted by the Liquidity Provider
  debug "Alice try to finalize the swap before getting accepted by the Liquidity Provider"
  submitMustFail alice do
    exerciseCmd usdtToBtcSwapRequestCid FinalizeSwap
  
  return ()