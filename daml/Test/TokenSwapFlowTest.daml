module Test.TokenSwapFlowTest where

import Daml.Script
import DA.Assert ((===))
import DA.Optional
import Exchange.TokenSwap
import Exchange.TokenPair
import Currency.TokenMetadata

import Scripts.PartyManagement
import Scripts.PartyUtils
import Scripts.TokenPairUtils
import Scripts.SwapUtils
import Scripts.SetupUtils

tokenSwapFlowTest = do
   -- Registry setup & party registration
  registryCid <- initializeRegistry
  adminOpt <- getAdminParty
  let admin = fromSome adminOpt
  [alice, bob, lp, btcOwner, usdtOwner] <- allocateAndRegisterParties admin ["Alice", "Bob", "LiquidityProvider", "BtcOwner", "UsdtOwner"]

  -- Token setup
  btcMetadata <- createMetadata "Bitcoin" "BTC" "Decentralized digital currency" 8
  usdtMetadata <- createMetadata "Tether" "USDT" "Stablecoin pegged to USD" 6

  -- Initializing BTC and USDT tokens
  (btcMasterCid, btcOwnerLedgerCid) <- createToken 
    btcOwner btcMetadata 100.0 admin

  (usdtMasterCid, usdtOwnerLedgerCid) <- createToken 
    usdtOwner usdtMetadata 1000000000.0 admin

  -- Create token listings
  let
    btcMasterKey = (btcOwner, btcMetadata.symbol)
    usdtMasterKey = (usdtOwner, usdtMetadata.symbol)

  -- create token listing
  (btcListingCid, btcListingKey) <- createTokenListing btcOwner admin btcMetadata.symbol admin

  (usdtListingCid, usdtListingKey) <- createTokenListing usdtOwner admin usdtMetadata.symbol admin

  -- Create token pair using listings
  tokenPairSetupCid <- createTokenPairSetup admin lp btcMasterKey usdtMasterKey admin

  -- Create a token pair using listings
  tokenPairCid <- createTokenPairWithSetup admin tokenPairSetupCid 109512.0 109483.0 admin

  -- Fund Alice and Liquidity Provider
  -- create USDT TokenTransferLock for Alice
  aliceTokenTransferLockCid <- createTokenTransferLock usdtOwner alice usdtOwnerLedgerCid 200000.0

  -- create BTC TokenTransferLock for Liquidity Provider
  lpTokenTransferLockCid <- createTokenTransferLock btcOwner lp btcOwnerLedgerCid 10.0

  -- Accept the TokenTransferLock for Alice
  aliceTokenLedgerCid <- acceptTokenTransfer alice aliceTokenTransferLockCid

  -- Accept the TokenTransferLock for Liquidity Provider
  lpTokenLedgerCid <- acceptTokenTransfer lp lpTokenTransferLockCid

  let btcUsdtTokenPairKey = (admin, btcMasterKey, usdtMasterKey)
  
  activeBTCUSDTTokenPairOpt <- getActiveTokenPairByKey admin btcUsdtTokenPairKey
  let activeBTCUSDTTokenPairCid = (fromSome activeBTCUSDTTokenPairOpt)

  (sellingPrice, buyingPrice) <- submit alice do
    exerciseCmd activeBTCUSDTTokenPairCid GetRate with requester = alice

  sellingPrice === 109512.0
  buyingPrice === 109483.0

  -- Alice wants to buy BTC with 1095.12 USDT
  let usdtInputAmount: Decimal = 1095.12
  let btcInputAmount: Decimal = 1.0

  -- Calculate the amount of BTC that Alice will receive when she buys BTC with USDT
  let estimatedReceivingBtcAmount = calculateSellingAmount usdtInputAmount sellingPrice
  debug $ "Estimated receiving amount of BTC for " <> show usdtInputAmount <> " USDT: " <> show estimatedReceivingBtcAmount

  -- Calculate the amount of USDT that Alice will receive when she sells BTC for USDT
  let estimatedReceivingUsdtAmount = calculateBuyingAmount btcInputAmount buyingPrice
  debug $ "Estimated receiving amount of USDT for " <> show btcInputAmount <> " BTC: " <> show estimatedReceivingUsdtAmount


  -- Alice create a TokenSwapRequest
  swapRequestCid <- createSwapWithTokenLocking 
    alice admin lp 
    (admin, alice) btcUsdtTokenPairKey 
    usdtInputAmount estimatedReceivingBtcAmount 
    admin

  [(requestCid, request)] <- query @SwapRequest alice
  requestCid === swapRequestCid
  request.swapper === alice
  request.admin === admin
  request.liquidityProvider === lp
  request.tokenPairKey === btcUsdtTokenPairKey
  request.inputAmount === usdtInputAmount
  request.expectedOutputAmount === estimatedReceivingBtcAmount

  debug $ "Swap request created: " <> show request

  debug "---------------------------------"

  -- Liquidity Provider accept the SwapRequest
  -- acceptSwapRequestCid <- submit lp do
    -- exerciseCmd swapRequest
  return () 
