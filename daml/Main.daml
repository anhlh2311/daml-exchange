module Main where

import Daml.Script
import DA.Optional (fromSome)
import Currency.TokenLedger
import Currency.TokenMetadata
import Exchange.TokenListing
import Exchange.TokenPair
import Scripts.PartyManagement
import Scripts.PartyUtils

setup: Script ()
setup = do
    -- initialize party registry
    registryCid <- initializeRegistry
    adminOpt <- getAdminParty
    let admin = fromSome adminOpt

    -- allocate parties
    usdcOwner <- allocateAndRegisterParty admin "USDCOwner"
    btcOwner <- allocateAndRegisterParty admin "BTCOwner"
    liquidityProvider <- allocateAndRegisterParty admin "LiquidityProvider"
    alice <- allocateAndRegisterParty admin "Alice"
    bob <- allocateAndRegisterParty admin "Bob"
    charlie <- allocateAndRegisterParty admin "Charlie"

    -- create token metadata
    -- usdtMetadata <- createMetadata "Tether USD" "USDT"
    usdcMetadata <- createMetadata "USD Coin" "USDC" "USD COIN" 6
    btcMetadata <- createMetadata "Bitcoin" "BTC" "Decentralized digital currency" 8

    -- -- create token setup
    setupUSDCid <- submit usdcOwner do
        createCmd TokenSetup with
            owner = usdcOwner
            initialSupply = 1000000.00
            metadata = usdcMetadata
            registryKey = admin

    (usdcMasterCid, usdcTokenLedgerCid) <- submit usdcOwner do
        exerciseCmd setupUSDCid Initialize

    setupBTCid <- submit btcOwner do
        createCmd TokenSetup with
            owner = btcOwner
            initialSupply = 100000.00
            metadata = btcMetadata
            registryKey = admin

    (btcMasterCid, btcTokenLedgerCid) <- submit btcOwner do
        exerciseCmd setupBTCid Initialize

    -- create USDC TokenListing 
    usdcTokenListingRequestCid <- submit usdcOwner do
        createCmd ListingRequest with
            tokenOwner = usdcOwner
            admin = admin
            tokenMasterKey = (usdcOwner, "USDC")
            registryKey = admin

    usdcTokenListingCid <- submit admin do
        exerciseCmd usdcTokenListingRequestCid ApproveListing

    -- create BTC TokenListing 
    btcTokenListingRequestCid <- submit btcOwner do
        createCmd ListingRequest with
            tokenOwner = btcOwner
            admin = admin
            tokenMasterKey = (btcOwner, "BTC")
            registryKey = admin

    btcTokenListingCid <- submit admin do
        exerciseCmd btcTokenListingRequestCid ApproveListing

    -- Create USDC-BTC TokenPair
    btcUsdcTokenPairSetupCid <- submit admin do
        createCmd TokenPairSetup with
            admin
            liquidityProvider
            inputListingKey = (btcOwner, (btcOwner, "BTC"))
            quoteListingKey = (usdcOwner, (usdcOwner, "USDC"))
            registryKey = admin

    btcUsdcTokenPairCid <- submit admin do
        exerciseCmd btcUsdcTokenPairSetupCid CreateTokenPair with
            sellingPrice = 108608.00
            buyingPrice = 108589.00

    return ()