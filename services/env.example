# Daml Ledger Configuration
LEDGER_HOST=localhost
LEDGER_PORT=7575
LEDGER_USE_TLS=false

# Liquidity Provider Configuration
LIQUIDITY_PROVIDER_PARTY=LiquidityProvider
ADMIN_PARTY=Admin

# Service Configuration
LOG_LEVEL=info
POLLING_INTERVAL_MS=5000

# Auto-Accept Configuration (set to true to automatically accept valid swaps)
AUTO_ACCEPT_SWAPS=false
MAX_ACCEPTABLE_SLIPPAGE=0.1

# Token Balance Thresholds (minimum balances to maintain)
MIN_BTC_BALANCE=1.0
MIN_USDT_BALANCE=100000.0 