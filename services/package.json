{
  "name": "liquidity-provider-service",
  "version": "1.0.0",
  "description": "Daml-based liquidity provider service for token exchange",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rm -rf dist",
    "create-swap": "ts-node scripts/createSwapRequest.ts",
    "create-swap:generate": "ts-node scripts/createSwapRequest.ts --generate-only",
    "swap-examples": "ts-node scripts/swap-examples.ts",
    "swap:list": "npm run swap-examples list",
    "swap:usdc-btc": "npm run swap-examples run usdcToBtc",
    "swap:btc-usdc": "npm run swap-examples run btcToUsdc",
    "swap:run-all": "npm run swap-examples run-all",
    "swap:generate-usdc-btc": "npm run swap-examples -- --generate-only run usdcToBtc",
    "swap:generate-btc-usdc": "npm run swap-examples -- --generate-only run btcToUsdc",
    "swap:generate-all": "npm run swap-examples -- --generate-only run-all"
  },
  "dependencies": {
    "@daml.js/exchange-0.0.1": "file:../daml.js/exchange-0.0.1",
    "@daml/ledger": "^2.10.1",
    "@daml/types": "^2.10.1",
    "@mojotech/json-type-validation": "^3.1.0",
    "dotenv": "^16.0.3",
    "winston": "^3.8.2"
  },
  "devDependencies": {
    "@types/node": "^18.15.0",
    "nodemon": "^3.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0"
  },
  "keywords": [
    "daml",
    "blockchain",
    "liquidity-provider",
    "token-exchange"
  ],
  "author": "",
  "license": "ISC"
}
